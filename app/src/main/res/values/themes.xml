<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NongjiQianwen" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:navigationBarColor">@android:color/white</item>
    </style>

    <style name="Theme.NongjiQianwen.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/transparent_splash_icon</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
        <item name="postSplashScreenTheme">@style/Theme.NongjiQianwen</item>
    </style>
</resources>
