PORT=3000
TZ=Asia/Shanghai
DASHSCOPE_API_KEY_1=replace-with-dashscope-primary-key
DASHSCOPE_API_KEY_2=replace-with-dashscope-backup-key
DASHSCOPE_API_KEY_3=
DASHSCOPE_API_KEY=
DASHSCOPE_API_KEYS=
DASHSCOPE_KEY_COOLDOWN_SECONDS=1
DASHSCOPE_KEY_SELECTION_MODE=fallback
# fallback: primary key first, secondary key only on pre-stream failover.
# auto remains available for future high-traffic smoothing.
DASHSCOPE_AUTO_ROUND_ROBIN_MIN_REQUESTS=200
DASHSCOPE_AUTO_ROUND_ROBIN_TOKEN_THRESHOLD=600000
DASHSCOPE_AUTO_ROUND_ROBIN_WINDOW_SECONDS=10
DASHSCOPE_AUTO_ROUND_ROBIN_HOLD_SECONDS=120
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CHAT_PRIMARY_ENABLED=false
CHAT_PRIMARY_PROVIDER_LABEL=中转站
CHAT_PRIMARY_API_MODE=responses
CHAT_PRIMARY_BASE_URL=https://example-primary-compatible-gateway
CHAT_PRIMARY_RESPONSES_URL=
CHAT_PRIMARY_CHAT_COMPLETIONS_URL=
CHAT_PRIMARY_API_KEY=replace-with-primary-chat-key
CHAT_PRIMARY_MODEL=gpt-5.5
CHAT_PRIMARY_RESPONSES_REASONING_EFFORT=low
CHAT_PRIMARY_RESPONSES_SEARCH_CONTEXT_SIZE=low
CHAT_PRIMARY_FIRST_VISIBLE_TIMEOUT_SECONDS=6
CHAT_PRIMARY_DIAL_TIMEOUT_SECONDS=6
CHAT_PRIMARY_TLS_HANDSHAKE_TIMEOUT_SECONDS=6
CHAT_PRIMARY_RESPONSE_HEADER_TIMEOUT_SECONDS=6
CHAT_PRIMARY_IDLE_CONN_TIMEOUT_SECONDS=60
MYSQL_URL=mysql://root:password@127.0.0.1:3306/nongji
APP_SECRET=replace-with-strong-secret
AUTH_STRICT=true
AUTH_SESSION_DAYS=3650
ACCESS_LOG_SLOW_MS=3000
LOG_FILE_PATH=/var/log/nongjiqiancha/server.log
BASE_PUBLIC_URL=https://your-domain.example.com
UPLOAD_BASE_URL=https://your-domain.example.com
IP2REGION_V4_XDB_PATH=/opt/nongjiqiancha/ip2region/ip2region_v4.xdb
IP2REGION_V6_XDB_PATH=
SUPPORT_ADMIN_SECRET=replace-with-support-admin-secret
DAILY_AGRI_JOB_SECRET=replace-with-daily-agri-job-secret
ADMIN_BOOTSTRAP_USERNAME=replace-with-admin-username
ADMIN_BOOTSTRAP_PASSWORD=replace-with-temporary-admin-password
ADMIN_BOOTSTRAP_DISPLAY_NAME=运营后台管理员
ADMIN_BOOTSTRAP_ROLE=owner
ADMIN_BOOTSTRAP_UPDATE_EXISTING=false
REDIS_ADDR=127.0.0.1:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
DYPNS_ACCESS_KEY_ID=replace-with-dypns-access-key
DYPNS_ACCESS_KEY_SECRET=replace-with-dypns-secret
DYPNS_REGION_ID=cn-hangzhou
DYPNS_FUSION_SCHEME_CODE=replace-with-fusion-scheme-code
DYPNS_ANDROID_PACKAGE_NAME=com.nongjiqiancha
DYPNS_ANDROID_PACKAGE_SIGN=replace-with-release-sign-md5-no-colon-lowercase
DYPNS_SMS_SIGN_NAME=replace-with-sms-sign-name
DYPNS_SMS_TEMPLATE_CODE=replace-with-sms-template-code
DYPNS_SMS_TEMPLATE_PARAM={"code":"##code##","min":"5"}
UPLOAD_STORAGE_BACKEND=oss
OSS_ENDPOINT=https://oss-cn-beijing-internal.aliyuncs.com
OSS_BUCKET=nongjiqiancha-prod
OSS_UPLOAD_PREFIX=uploads
OSS_ACCESS_KEY_ID=replace-with-ram-access-key
OSS_ACCESS_KEY_SECRET=replace-with-ram-access-secret
CLIENT_APP_LOG_RATE_LIMIT_WINDOW_SECONDS=600
CLIENT_APP_LOG_RATE_LIMIT_MAX_HITS=60
CLIENT_APP_LOG_RATE_LIMIT_PRUNE_INTERVAL_SECONDS=600
GIFT_CARD_REDEEM_RATE_LIMIT_WINDOW_SECONDS=3600
GIFT_CARD_REDEEM_RATE_LIMIT_MAX_HITS=10
GIFT_CARD_REDEEM_RATE_LIMIT_PRUNE_INTERVAL_SECONDS=600
APP_ANDROID_LATEST_VERSION_CODE=
APP_ANDROID_LATEST_VERSION_NAME=
APP_ANDROID_APK_URL=
APP_ANDROID_APK_SHA256=
APP_ANDROID_RELEASE_NOTES=
APP_ANDROID_FORCE_UPDATE=false
APP_ANDROID_FILE_SIZE_BYTES=
